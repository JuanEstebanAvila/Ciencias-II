package Conteo;
import java.util.Scanner;

// HashSimulado v3 - Inspirado en SHA-256
// Salida fija de 64 caracteres hexadecimales = 256 bits
public class HashSimulado {

    // ---------------------------------------------------------------
    // CONSTANTES DE RONDA
    // Inspirado en SHA-256: basadas en raíces cuadradas de primos.
    // Se mezclan con el estado en cada iteración para dificultar
    // patrones predecibles en la salida.
    // ---------------------------------------------------------------
    private static final long[] CONSTANTES = {
        0x428a2f98d728ae22L,  // primo 2
        0x7137449123ef65cdL,  // primo 3
        0xb5c0fbcfec4d3b2fL,  // primo 5
        0xe9b5dba58189dbbcL   // primo 7
    };

    public static String generarHash(String palabra, String sal) {
        String entrada = palabra + sal;

        // ---------------------------------------------------------------
        // ESTADO INICIAL: 4 bloques de 64 bits = 256 bits en total
        // Tomados de los valores iniciales reales de SHA-256
        // (raíces cuadradas de los primeros 4 primos, parte fraccionaria)
        // ---------------------------------------------------------------
        long[] estado = {
            0x6a09e667f3bcc908L,  // bloque 0
            0xbb67ae8584caa73bL,  // bloque 1
            0x3c6ef372fe94f82bL,  // bloque 2
            0xa54ff53a5f1d36f1L   // bloque 3
        };

        // ---------------------------------------------------------------
        // RONDA 1: procesar cada carácter de la entrada
        // ---------------------------------------------------------------
        for (int i = 0; i < entrada.length(); i++) {
            int ascii = entrada.charAt(i); // V1: valor ASCII directo (sin pérdida de info)
            int b = i % 4;                 // cada carácter afecta un bloque distinto

            // -- Mezcla del bloque actual (V1 + V2) --
            estado[b] = (estado[b] * 131L) ^ ascii;          // multiplicación + XOR con ASCII  (V1+V2)
            estado[b] = Long.rotateLeft(estado[b], 5);        // rotación de bits                (V2)
            estado[b] ^= (estado[b] >>> 7);                   // segunda mezcla con shift        (V2)
            estado[b] ^= CONSTANTES[b];                       // XOR con constante de ronda      (NUEVO)

            // -- Mezcla cruzada entre bloques (NUEVO - inspirado en SHA-256) --
            // Un cambio en un carácter afecta los 4 bloques: efecto avalancha
            estado[(b + 1) % 4] ^= Long.rotateLeft(estado[b], 13);
            estado[(b + 2) % 4] ^= (estado[b] >>> 17);
            estado[(b + 3) % 4] += estado[b];
        }

        // ---------------------------------------------------------------
        // RONDA 2: finalización (4 pasadas de mezcla global)
        // Garantiza avalancha completa incluso en entradas cortas
        // ---------------------------------------------------------------
        for (int r = 0; r < 4; r++) {
            for (int b = 0; b < 4; b++) {
                estado[b] = Long.rotateLeft(estado[b], 7);
                estado[b] ^= estado[(b + 1) % 4];
                estado[b] ^= CONSTANTES[b];
                estado[b] ^= (estado[b] >>> 13);
            }
        }

        // ---------------------------------------------------------------
        // SALIDA: 4 bloques × 16 caracteres hex = 64 caracteres SIEMPRE
        // %016x → hexadecimal, mínimo 16 chars, relleno con ceros
        // Total: 64 caracteres = 256 bits, longitud fija garantizada
        // ---------------------------------------------------------------
        return String.format("%016x%016x%016x%016x",
                estado[0], estado[1], estado[2], estado[3]);
    }

    public static void main(String[] args) {
        System.out.println("HashSimulado v3 - 256 bits");

        System.out.println("Digite la palabra que quiere cifrar:");
        Scanner palabrasc = new Scanner(System.in);
        String palabraSecreta = palabrasc.nextLine().toUpperCase();
        String sal = "Z9xY";

        String hashGenerado = generarHash(palabraSecreta, sal);

        System.out.println("\n── Resultado ──────────────────────────────────────────────────────");
        System.out.println("Hash (256 bits): " + hashGenerado);
        System.out.println("Longitud:        " + hashGenerado.length() + " caracteres hexadecimales = 256 bits");
        System.out.println("───────────────────────────────────────────────────────────────────\n");

        // Demostrar que la longitud es siempre la misma
        System.out.println("── Verificación de longitud fija ──────────────────────────────────");
        String[] pruebas = {"A", "HOLA", "PROGRAMACION", "UNATEXTOMUYLARGOPARAPROBAR"};
        for (String p : pruebas) {
            String h = generarHash(p, sal);
            System.out.println("\"" + p + "\" → " + h.length() + " chars → " + h);
        }
        System.out.println("───────────────────────────────────────────────────────────────────\n");

        System.out.println("¡Iniciando Ataque de Diccionario!");
        System.out.println("Objetivo:\n" + hashGenerado + "\n");

        String[] diccionario = {
                "HOLA", "SISTEMAS", "COMPUTACION", "JAVA",
                "PROGRAMACION", "CIENCIAS", "12345", "ADMIN", "SECRETO"
        };

        boolean encontrado = false;
        for (String intento : diccionario) {
            String hashCalculado = generarHash(intento, sal);
            System.out.println("Probando: " + intento);
            System.out.println("          " + hashCalculado);

            if (hashCalculado.equals(hashGenerado)) {
                System.out.println("\n¡BINGO! SEGURIDAD VULNERADA.");
                System.out.println("La palabra original es: " + intento);
                encontrado = true;
                break;
            }
        }

        if (!encontrado) {
            System.out.println("\nAtaque fallido. La palabra no estaba en el diccionario del atacante.");
        }

        palabrasc.close();
    }
}
